@model List<StorageManagement.ViewModels.ProductIndexViewModel>

@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4">Storage Products</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Add Product</a>
    <a asp-action="Reports" class="btn btn-secondary">Reports</a>
</div>

<form method="get" class="row mb-4">
    <div class="col-md-5">
        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name..." />
    </div>

    <div class="col-md-3">
        <input type="number" name="minQuantity" value="@ViewBag.MinQuantity" class="form-control" placeholder="Min quantity..." />
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-success w-100">Filter</button>
    </div>

    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Manufacturer</th>
            <th>Type</th>
            <th>Supplier</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Total Value</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>
                    <img src="@product.ImageUrl" alt="@product.Name" style="width:80px;height:60px;object-fit:contain;" />
                </td>
                <td>@product.Name</td>
                <td>@product.Manufacturer</td>
                <td>@product.ProductType</td>
                <td>@product.Supplier</td>
                <td>@product.Quantity</td>
                <td>@product.Price.ToString("F2") лв.</td>
                <td>@product.TotalValue.ToString("F2") лв.</td>
                <td>
                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
