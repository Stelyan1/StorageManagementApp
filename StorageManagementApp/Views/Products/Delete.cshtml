@model StorageManagement.ViewModels.ProductFormViewModel

@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this product?
</div>

<div class="card mb-3" style="max-width: 600px;">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p><strong>Manufacturer:</strong> @Model.Manufacturer</p>
        <p><strong>Type:</strong> @Model.ProductType</p>
        <p><strong>Supplier:</strong> @Model.Supplier</p>
        <p><strong>Quantity:</strong> @Model.Quantity</p>
        <p><strong>Price:</strong> @Model.Price.ToString("F2") лв.</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>