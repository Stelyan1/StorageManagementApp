@model StorageManagement.ViewModels.ProductFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="mb-3">
    <label asp-for="Name" class="form-label"></label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="ImageUrl" class="form-label"></label>
    <input asp-for="ImageUrl" class="form-control" />
    <span asp-validation-for="ImageUrl" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Manufacturer" class="form-label"></label>
    <input asp-for="Manufacturer" class="form-control" />
    <span asp-validation-for="Manufacturer" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="ProductType" class="form-label"></label>
    <input asp-for="ProductType" class="form-control" placeholder="GPU, CPU, RAM, Monitor..." />
    <span asp-validation-for="ProductType" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Supplier" class="form-label"></label>
    <input asp-for="Supplier" class="form-control" />
    <span asp-validation-for="Supplier" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Quantity" class="form-label"></label>
    <input asp-for="Quantity" class="form-control" />
    <span asp-validation-for="Quantity" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Price" class="form-label"></label>
    <input asp-for="Price" class="form-control" />
    <span asp-validation-for="Price" class="text-danger"></span>
</div>